# VexCTX Service Configuration

# General Server Port
VEXCTX_PORT=8765

# Data Storage Paths
VEXCTX_DB_PATH=~/.vexctx/metadata.db
VEXCTX_VECTOR_PATH=~/.vexctx/vectors
VEXCTX_VAULT_PATH=~/.vexctx/vaults

# Local Key Storage
VEXCTX_LOCAL_MASTER_KEY_PATH=~/.vexctx/master.key

# Redis cache connection URL (optional)
VEXCTX_REDIS_URL=redis://localhost:6379/3

# Vector Database (Qdrant) Configuration
# Modes: 
#   - ":memory:" (transient in-memory)
#   - "/path/to/db/dir" (local on-disk path, e.g. ~/.vexctx/qdrant_data)
#   - "http://localhost:6333" (remote server)
VEXCTX_QDRANT_URL=:memory:
VEXCTX_QDRANT_COLLECTION=vexctx_vectors

# AI Service Configuration (Local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
VEXCTX_LLM_MODEL=llama3.2:3b
VEXCTX_EMBED_PROVIDER=ollama
VEXCTX_EMBED_MODEL=nomic-embed-text
VEXCTX_EMBED_DIMENSIONS=768
VEXCTX_SUMMARY_PROVIDER=ollama
VEXCTX_SUMMARY_MODEL=llama3.2:3b

# Gating & Plan Settings
# Set to "free" to test the restricted Vault mode (returns HTTP 402 on search).
# Set to "pro" to test semantic search, summaries, and agent bundles.
VEXCTX_PLAN_TYPE=free

# Privacy Filters
VEXCTX_EXCLUDED_APPS=password_manager,banking_app
VEXCTX_LOCAL_ONLY=true
