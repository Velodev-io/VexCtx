{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VexCTX",
  "version": "1.0.0",
  "identifier": "com.velodev.vexctx",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "VexCTX Vault",
        "width": 900,
        "height": 650,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/vexctx-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCM0RCNDdCQUUzRTZBQTAKUldTZ2FqNnVlN1E5ZXlEUDNOc21tMTRqOWp4ZlFjZEhYRDhxTGQ0K1R4ajZXd2JwTUxBMkh1M1QK",
      "endpoints": [
        "https://vexctx.io/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
